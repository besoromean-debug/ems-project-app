# 3. Siguraduhing naka-add lahat ng files (pakicheck kung may .gitignore ka na)
git add .
# 4. GUMAWA NG COMMIT (Ito ang pinaka-importante para mawala ang refspec error)
git commit -m "Initial commit - EMS Project files"
# 5. I-set ang main branch
git branch -M main
