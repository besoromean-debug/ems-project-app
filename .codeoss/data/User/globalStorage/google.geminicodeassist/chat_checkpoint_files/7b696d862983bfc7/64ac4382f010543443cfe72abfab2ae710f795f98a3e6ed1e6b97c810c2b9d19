<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>EMS - Dashboard</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.0/font/bootstrap-icons.css">
    <style>
        html, body {
            height: 100%;
            margin: 0;
            background: #0f172a !important;
            background: linear-gradient(180deg, #0f172a 0%, #312e81 100%) no-repeat fixed !important;
            color: white;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        }
        .sidebar { 
            min-height: 100vh;
            background: rgba(15, 23, 42, 0.95) !important; 
            backdrop-filter: blur(10px);
            border-right: 1px solid rgba(255, 255, 255, 0.1);
        }
        .nav-link { color: rgba(255,255,255,.7) !important; transition: all 0.3s ease; }
        .nav-link:hover { color: white !important; background: rgba(255,255,255,0.1); border-radius: 5px; }
        .nav-link.active { color: white !important; background: #3b82f6 !important; border-radius: 5px; }
        .card {
            background: rgba(30, 41, 59, 0.7) !important;
            backdrop-filter: blur(10px);
            border: 1px solid rgba(255, 255, 255, 0.1);
            color: white;
            border-radius: 1rem;
        }
        .text-muted { color: rgba(255,255,255,0.5) !important; }
        .border-bottom { border-bottom: 1px solid rgba(255,255,255,0.1) !important; }
        #userBadge { background-color: #3b82f6 !important; }
    </style>
</head>
<body>
    <div class="container-fluid">
        <div class="row">
            <!-- Sidebar -->
            <nav class="col-md-2 d-none d-md-block sidebar p-3">
                <h4 class="text-center mb-4">EMS Admin</h4>
                <ul class="nav flex-column gap-2">
                    <li class="nav-item"><a class="nav-link active" href="#"><i class="bi bi-speedometer2 me-2"></i> Dashboard</a></li>
                    <li class="nav-item"><a class="nav-link" href="#"><i class="bi bi-people me-2"></i> Employees</a></li>
                    <li class="nav-item"><a class="nav-link" href="#"><i class="bi bi-gear me-2"></i> Settings</a></li>
                    <hr>
                    <li class="nav-item"><a class="nav-link text-danger" href="/logout"><i class="bi bi-box-arrow-right me-2"></i> Logout</a></li>
                </ul>
            </nav>

            <!-- Main Content -->
            <main class="col-md-10 ms-sm-auto p-4">
                <div class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pt-3 pb-2 mb-3 border-bottom">
                    <h1 class="h2 text-white">Admin Dashboard</h1>
                    <div class="btn-toolbar mb-2 mb-md-0">
                        <span class="badge bg-primary p-2" id="userBadge">Loading...</span>
                    </div>
                </div>

                <div class="row g-4">
                    <div class="col-md-4">
                        <div class="card shadow-sm border-0">
                            <div class="card-body">
                                <h5 class="card-title text-muted">Total Employees</h5>
                                <h2 class="mb-0 text-white">24</h2>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="card shadow-sm border-0">
                            <div class="card-body">
                                <h5 class="card-title text-muted">Active Sessions</h5>
                                <h2 class="mb-0 text-success">3</h2>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="card shadow-sm border-0">
                            <div class="card-body">
                                <h5 class="card-title text-muted">Pending Requests</h5>
                                <h2 class="mb-0 text-warning">5</h2>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="mt-5">
                    <h4>System Status</h4>
                    <div class="alert bg-primary bg-opacity-10 text-white border-0 shadow-sm" style="backdrop-filter: blur(5px); border: 1px solid rgba(255,255,255,0.1) !important;">
                        <i class="bi bi-shield-check me-2"></i> 
                        Securely logged in. Cyber Level 2 Security protocols are active.
                    </div>
                </div>
            </main>
        </div>
    </div>

    <script>
        // Fetch user data from our new API endpoint
        fetch('/api/user')
            .then(res => res.json())
            .then(data => document.getElementById('userBadge').innerText = 'User: ' + data.username);
    </script>
</body>
</html>