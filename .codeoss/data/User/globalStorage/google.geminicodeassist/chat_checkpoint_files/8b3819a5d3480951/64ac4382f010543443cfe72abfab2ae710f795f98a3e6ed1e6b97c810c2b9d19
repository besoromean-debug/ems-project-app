<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>EMS - Dashboard</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.0/font/bootstrap-icons.css">
    <style>
        html, body {
            height: 100%;
            margin: 0;
            background-color: #f8f9fa !important;
            color: #333;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        }
        .sidebar { 
            min-height: 100vh;
            background-color: #2c3e50 !important;
            color: #ffffff !important;
            border-right: none;
        }
        .sidebar h4 {
            color: #ffffff !important;
        }
        .nav-link { color: rgba(255,255,255,0.7) !important; transition: all 0.3s ease; }
        .nav-link:hover { color: #ffffff !important; background: rgba(255, 255, 255, 0.1); border-radius: 5px; }
        .nav-link.active { color: white !important; background: #3b82f6 !important; border-radius: 5px; }
        .card {
            background-color: #ffffff !important;
            color: #333;
            border-radius: 1rem;
            box-shadow: 0 0.125rem 0.25rem rgba(0, 0, 0, 0.075) !important;
        }
        .table { color: #333 !important; }
        .table-light { background-color: #f8f9fa !important; }
        .modal-content { background: #ffffff; color: #333; }
        .form-control { background: #ffffff; border: 1px solid #dee2e6; color: #333; }
        .form-control:focus { background: #ffffff; color: #333; border-color: #3b82f6; box-shadow: none; }
        #userBadge { background-color: #3b82f6 !important; }
        .status-pulse {
            width: 10px; height: 10px; background: #10b981; border-radius: 50%;
            display: inline-block; animation: pulse 2s infinite;
        }
        @keyframes pulse { 0% { opacity: 1; } 50% { opacity: 0.4; } 100% { opacity: 1; } }
    </style>
</head>
<body>
    <div class="container-fluid">
        <div class="row">
            <!-- Sidebar -->
            <nav class="col-md-2 d-none d-md-block sidebar p-3">
                <h4 class="text-center mb-4">EMS Admin</h4>
                <ul class="nav flex-column gap-2">
                    <li class="nav-item"><a class="nav-link active" href="/dashboard"><i class="bi bi-speedometer2 me-2"></i> Dashboard</a></li>
                    <li class="nav-item"><a class="nav-link" href="/employees"><i class="bi bi-people me-2"></i> Employees</a></li>
                    <li class="nav-item"><a class="nav-link" href="#"><i class="bi bi-gear me-2"></i> Settings</a></li>
                    <hr>
                    <li class="nav-item"><a class="nav-link text-danger" href="/logout"><i class="bi bi-box-arrow-right me-2"></i> Logout</a></li>
                </ul>
            </nav>

            <!-- Main Content -->
            <main class="col-md-10 ms-sm-auto p-4" style="background: transparent;">
                <div class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pt-3 pb-2 mb-3 border-bottom">
                    <h1 class="h2">System Overview</h1>
                    <div class="btn-toolbar mb-2 mb-md-0">
                        <span class="badge bg-primary p-2" id="userBadge">Loading...</span>
                    </div>
                </div>

                <div class="row g-4">
                    <div class="col-md-4">
                        <div class="card shadow-sm border-0">
                            <div class="card-body">
                                <h5 class="card-title text-secondary">Total Employees</h5>
                                <h2 class="mb-0" id="totalEmployeesCount">0</h2>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="card shadow-sm border-0">
                            <div class="card-body">
                                <h5 class="card-title text-secondary">Active Sessions</h5>
                                <h2 class="mb-0 text-success">3</h2>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="card shadow-sm border-0">
                            <div class="card-body">
                                <h5 class="card-title text-secondary">Pending Requests</h5>
                                <h2 class="mb-0 text-warning">5</h2>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="mt-5 text-center py-5 opacity-25">
                    <i class="bi bi-graph-up-arrow display-1"></i>
                    <p class="mt-3">Select <b>Employees</b> from the sidebar to manage staff records.</p>
                </div>
            </main>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        function loadStats() {
            fetch('/api/employees')
                .then(res => res.json())
                .then(data => document.getElementById('totalEmployeesCount').innerText = data.length);
        }

        // Page Initialization
        fetch('/api/user')
            .then(res => res.json())
            .then(data => document.getElementById('userBadge').innerText = 'User: ' + data.username);
        
        loadStats();
    </script>
</body>
</html>